<UserControl x:Class="WindowWise.Controls.FeatureCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Name="Root">
    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <Border Width="38" Height="38" HorizontalAlignment="Left" Background="#EEF4FF" CornerRadius="8">
                <Viewbox Width="21" Height="21" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Path Width="24" Height="24" Data="{Binding IconData, ElementName=Root}"
                          Stroke="#2563EB" Style="{StaticResource FeatureIconStyle}" />
                </Viewbox>
            </Border>
            <TextBlock Margin="0,14,0,0" FontSize="17" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" Text="{Binding Title, ElementName=Root}" />
            <TextBlock Margin="0,5,0,16" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                       Text="{Binding Description, ElementName=Root}" TextWrapping="Wrap" />
            <Button HorizontalAlignment="Left" Style="{StaticResource FeatureButtonStyle}"
                    Content="{Binding ActionText, ElementName=Root}" />
        </StackPanel>
    </Border>
</UserControl>
