<UserControl x:Class="WindowWise.Views.AudioManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="760"
             d:DesignWidth="950"
             mc:Ignorable="d">
    <UserControl.Resources>
        <SolidColorBrush x:Key="AudioPrimaryBrush" Color="#2878D4" />
        <SolidColorBrush x:Key="AudioPrimaryHoverBrush" Color="#1F68BE" />
        <SolidColorBrush x:Key="AudioSurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AudioPanelBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="AudioIconSurfaceBrush" Color="#EEF1F5" />
        <SolidColorBrush x:Key="AudioTrackBrush" Color="#D9DEE5" />

        <Style x:Key="AudioCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AudioSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="#E0E5EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Direction="270" Opacity="0.08" ShadowDepth="2" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AudioPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource AudioPrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="{StaticResource AudioPrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AudioSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AudioPrimaryButtonStyle}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#D4D9E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#F3F6F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AudioSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="#B4BDC8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="SwitchTrack" Background="{TemplateBinding Background}" CornerRadius="13">
                            <Ellipse x:Name="SwitchThumb"
                                     Width="20" Height="20" Margin="3"
                                     HorizontalAlignment="Left"
                                     Fill="White">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="3" Opacity="0.2" ShadowDepth="1" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{StaticResource AudioPrimaryBrush}" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AudioSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="22" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="5" Background="{StaticResource AudioTrackBrush}" CornerRadius="2.5" />
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Background="{StaticResource AudioPrimaryBrush}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="5" Background="{TemplateBinding Background}" CornerRadius="2.5" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="17" Height="17">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{StaticResource AudioPrimaryBrush}" Stroke="#1F68BE" StrokeThickness="1" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AudioIconTileStyle" TargetType="Border">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="64" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="Background" Value="{StaticResource AudioIconSurfaceBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource AudioPanelBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="34,28,34,38">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,22">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Text="Window Audio Manager" />
                    <Button HorizontalAlignment="Right" Style="{StaticResource AudioSecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE72C;" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Grid.Row="1" Background="#DDE2E8" />

                <Grid Grid.Row="2" Margin="0,28,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.8*" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Margin="0,0,0,14"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="Current Output Device" />

                        <Border Style="{StaticResource AudioCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="190" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource AudioIconTileStyle}">
                                    <Viewbox Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Width="24" Height="24"
                                              Data="{StaticResource AudioIconGeometry}"
                                              Stroke="#4B5868"
                                              Style="{StaticResource FeatureIconStyle}" />
                                    </Viewbox>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                               Text="Headphones (Realtek(R) Audio)" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,5,0,0" FontSize="13" Foreground="{StaticResource MutedTextBrush}" Text="Active" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="18,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Margin="0,0,0,10" FontSize="13" FontWeight="SemiBold" Text="Master volume" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="42" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Value="70" Maximum="100" Style="{StaticResource AudioSliderStyle}" />
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="13" Foreground="{StaticResource MutedTextBrush}" Text="70%" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Margin="0,28,0,14"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="Available Output Devices" />

                        <Border Margin="0,0,0,14" Style="{StaticResource AudioCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="205" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource AudioIconTileStyle}">
                                    <Viewbox Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path Width="24" Height="24" Data="{StaticResource AudioIconGeometry}" Stroke="#4B5868"
                                              Style="{StaticResource FeatureIconStyle}" />
                                    </Viewbox>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Speakers (Realtek(R) Audio)" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,5,0,0" FontSize="13" Foreground="{StaticResource MutedTextBrush}" Text="ID: 2" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,0,9" HorizontalAlignment="Right" Orientation="Horizontal">
                                        <ToggleButton Style="{StaticResource AudioSwitchStyle}" />
                                        <TextBlock Margin="9,0,0,0" VerticalAlignment="Center" FontSize="13" Text="Inactive" />
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="42" /></Grid.ColumnDefinitions>
                                        <Slider Value="50" Maximum="100" Style="{StaticResource AudioSliderStyle}" />
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Foreground="{StaticResource MutedTextBrush}" Text="50%" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Margin="0,0,0,14" Style="{StaticResource AudioCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="205" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource AudioIconTileStyle}">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontFamily="Segoe MDL2 Assets" FontSize="31" Foreground="#4B5868" Text="&#xE7F6;" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Headphones (Realtek(R) Audio)" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,5,0,0" FontSize="13" Foreground="{StaticResource MutedTextBrush}" Text="ID: 1" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,0,9" HorizontalAlignment="Right" Orientation="Horizontal">
                                        <ToggleButton IsChecked="True" Style="{StaticResource AudioSwitchStyle}" />
                                        <TextBlock Margin="9,0,0,0" VerticalAlignment="Center" FontSize="13" Text="Active" />
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="42" /></Grid.ColumnDefinitions>
                                        <Slider Value="70" Maximum="100" Style="{StaticResource AudioSliderStyle}" />
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Foreground="{StaticResource MutedTextBrush}" Text="70%" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource AudioCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="205" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource AudioIconTileStyle}">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontFamily="Segoe MDL2 Assets" FontSize="31" Foreground="#4B5868" Text="&#xE7F4;" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="16" FontWeight="SemiBold"
                                               Text="Dell S2719DGF (NVIDIA High Definition Audio)" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,5,0,0" FontSize="13" Foreground="{StaticResource MutedTextBrush}" Text="ID: 3" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="42" /></Grid.ColumnDefinitions>
                                        <Slider Value="40" Maximum="100" Style="{StaticResource AudioSliderStyle}" />
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Foreground="{StaticResource MutedTextBrush}" Text="40%" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Margin="0,0,0,14"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="Volume Presets" />

                        <Button Margin="0,0,0,16" Content="Save Current as Preset" Style="{StaticResource AudioPrimaryButtonStyle}" />

                        <Border Margin="0,0,0,14" Style="{StaticResource AudioCardStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="Gaming" />
                                <Button Width="80" HorizontalAlignment="Right" Content="Apply" Style="{StaticResource AudioPrimaryButtonStyle}" />
                            </Grid>
                        </Border>
                        <Border Margin="0,0,0,14" Style="{StaticResource AudioCardStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="Movie" />
                                <Button Width="80" HorizontalAlignment="Right" Content="Apply" Style="{StaticResource AudioPrimaryButtonStyle}" />
                            </Grid>
                        </Border>
                        <Border Margin="0,0,0,14" Style="{StaticResource AudioCardStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="Focus" />
                                <Button Width="80" HorizontalAlignment="Right" Content="Apply" Style="{StaticResource AudioPrimaryButtonStyle}" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource AudioCardStyle}">
                            <Grid>
                                <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="Music" />
                                <Button Width="80" HorizontalAlignment="Right" Content="Apply" Style="{StaticResource AudioPrimaryButtonStyle}" />
                            </Grid>
                        </Border>

                        <Border Margin="0,24,0,0" Padding="18" Background="#EAF3FD" CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#245E9B" Text="UI preview" />
                                <TextBlock Margin="0,5,0,0" FontSize="12" Foreground="#4D6D8E" TextWrapping="Wrap"
                                           Text="Controls are visual only. Audio device and preset actions will be connected later." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
