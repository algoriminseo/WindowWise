<Window x:Class="WindowWise.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowWise" Icon="/Assets/WindowWiseIcon.ico"
        Width="1180" Height="760"
        MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8" FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#111C2D">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="116" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Margin="24,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="28" Height="28" Margin="0,0,10,0"
                               Source="/Assets/WindowWiseIcon.ico" Stretch="Uniform" />
                        <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" Text="WindowWise" />
                    </StackPanel>
                    <TextBlock Margin="0,10,0,0" FontSize="11" Foreground="#7F8DA2"
                               Text="Convenient functionalities for Window users" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Margin="26,12,0,8" FontSize="11" FontWeight="SemiBold"
                               Foreground="#6F7D91" Text="WORKSPACE" />
                    <Button x:Name="OverviewButton" Click="OverviewButton_Click"
                            Style="{StaticResource PrimaryNavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="28" FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE80F;" />
                            <TextBlock Text="Overview" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SmartClipboardButton" Click="SmartClipboardButton_Click"
                            Style="{StaticResource NavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="18" Height="18" Margin="0,0,10,0">
                                <Path Width="24" Height="24" Data="{StaticResource ClipboardIconGeometry}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Style="{StaticResource FeatureIconStyle}" />
                            </Viewbox>
                            <TextBlock Text="Smart Clipboard" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="AudioManagerButton" Style="{StaticResource NavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="18" Height="18" Margin="0,0,10,0">
                                <Path Width="24" Height="24" Data="{StaticResource AudioIconGeometry}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Style="{StaticResource FeatureIconStyle}" />
                            </Viewbox>
                            <TextBlock Text="Window Audio Manager" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="WindowLayoutsButton" Style="{StaticResource NavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="18" Height="18" Margin="0,0,10,0">
                                <Path Width="24" Height="24" Data="{StaticResource LayoutIconGeometry}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Style="{StaticResource FeatureIconStyle}" />
                            </Viewbox>
                            <TextBlock Text="Window Layouts" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,18">
                    <Button Style="{StaticResource NavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="28" FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE713;" />
                            <TextBlock Text="Settings" />
                        </StackPanel>
                    </Button>
                    <TextBlock Margin="26,10,0,0" FontSize="11" Foreground="#5E6B7D" Text="WindowWise 0.1.0" />
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl x:Name="MainContent" Grid.Column="1" />
    </Grid>
</Window>
