<Window x:Class="WindowWise.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WindowWise.Controls"
        Title="WindowWise" Width="1180" Height="760"
        MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8" FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#111C2D">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="116" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="24,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="28" Height="28" Margin="0,0,10,0">
                            <Path Width="24" Height="24" Fill="#60A5FA" Stretch="Uniform"
                                  Data="M3,12V6.75L9,5.43V11.91L3,12M20,3V11.75L10,11.9V5.21L20,3M3,13L9,13.09V19.9L3,18.75V13M20,13.25V22L10,20.09V13.1L20,13.25Z" />
                        </Viewbox>
                        <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" Text="WindowWise" />
                    </StackPanel>
                    <TextBlock Margin="0,10,0,0" FontSize="11" Foreground="#7F8DA2"
                               Text="Convenient functionalities for Window users" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Margin="26,12,0,8" FontSize="11" FontWeight="SemiBold"
                               Foreground="#6F7D91" Text="WORKSPACE" />
                    <Button Style="{StaticResource PrimaryNavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="28" FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE80F;" />
                            <TextBlock Text="Overview" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="18" Height="18" Margin="0,0,10,0">
                                <Path Width="24" Height="24" Data="{StaticResource ClipboardIconGeometry}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Style="{StaticResource FeatureIconStyle}" />
                            </Viewbox>
                            <TextBlock Text="Smart Clipboard" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="18" Height="18" Margin="0,0,10,0">
                                <Path Width="24" Height="24" Data="{StaticResource AudioIconGeometry}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Style="{StaticResource FeatureIconStyle}" />
                            </Viewbox>
                            <TextBlock Text="Window Audio Manager" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="18" Height="18" Margin="0,0,10,0">
                                <Path Width="24" Height="24" Data="{StaticResource LayoutIconGeometry}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Style="{StaticResource FeatureIconStyle}" />
                            </Viewbox>
                            <TextBlock Text="Window Layouts" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,18">
                    <Button Style="{StaticResource NavigationButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="28" FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE713;" />
                            <TextBlock Text="Settings" />
                        </StackPanel>
                    </Button>
                    <TextBlock Margin="26,10,0,0" FontSize="11" Foreground="#5E6B7D" Text="WindowWise 0.1.0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Padding="30,0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Button Width="34" Height="34" HorizontalAlignment="Right" Background="Transparent"
                        BorderThickness="0" FontFamily="Segoe MDL2 Assets" FontSize="16"
                        Foreground="{StaticResource MutedTextBrush}" Content="&#xE7F4;" />
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource VerticalScrollBarStyle}" />
                </ScrollViewer.Resources>
                <StackPanel Margin="30,28,30,36">
                    <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Good afternoon" />
                    <TextBlock Margin="0,6,0,0" FontSize="14" Foreground="{StaticResource MutedTextBrush}"
                               Text="Your Windows workspace is ready." />

                    <ScrollViewer Margin="0,26,0,0" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource HorizontalScrollBarStyle}" />
                        </ScrollViewer.Resources>
                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                            <controls:FeatureCard Width="280" Margin="0,0,16,0"
                                Title="Smart Clipboard" Description="Search, organize and safely reuse clipboard items."
                                ActionText="Open clipboard" IconData="{StaticResource ClipboardIconGeometry}" />
                            <controls:FeatureCard Width="280" Margin="0,0,16,0"
                                Title="Window Audio Manager" Description="Manage devices, battery status and app volume presets."
                                ActionText="Open audio manager" IconData="{StaticResource AudioIconGeometry}" />
                            <controls:FeatureCard Width="280" Margin="0,0,16,0"
                                Title="Window Layouts" Description="Save and restore window positions."
                                ActionText="Open layouts" IconData="{StaticResource LayoutIconGeometry}" />
                            <controls:FeatureCard Width="280" Margin="0,0,16,0"
                                Title="Focus Mode" Description="Reduce distractions while working."
                                ActionText="Start focus mode" IconData="{StaticResource FocusIconGeometry}" />
                            <controls:FeatureCard Width="280" Margin="0,0,16,0"
                                Title="Automation" Description="Run common desktop tasks automatically."
                                ActionText="View automation" IconData="{StaticResource AutomationIconGeometry}" />
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Margin="0,22,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Recent activity" />
                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="28" Height="28" HorizontalAlignment="Left" Background="#EEF4FF" CornerRadius="6">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="13" Foreground="#2563EB" Text="&#xE8A7;" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}" Text="Development layout restored" />
                                        <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Text="3 applications positioned" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Text="12 min ago" />
                                </Grid>
                                <Border Height="1" Margin="0,14" Background="#EDF0F4" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="28" Height="28" HorizontalAlignment="Left" Background="#EEF4FF" CornerRadius="6">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="13" Foreground="#2563EB" Text="&#xE823;" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}" Text="Focus session completed" />
                                        <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Text="45 minutes" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Text="Yesterday" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Quick settings" />
                                <Grid Margin="0,18,0,0">
                                    <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextBrush}" Text="Launch at startup" />
                                    <ToggleButton HorizontalAlignment="Right" IsChecked="True" Content="On" />
                                </Grid>
                                <Grid Margin="0,16,0,0">
                                    <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextBrush}" Text="Notifications" />
                                    <ToggleButton HorizontalAlignment="Right" IsChecked="True" Content="On" />
                                </Grid>
                                <Grid Margin="0,16,0,0">
                                    <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextBrush}" Text="Compact mode" />
                                    <ToggleButton HorizontalAlignment="Right" Content="Off" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
